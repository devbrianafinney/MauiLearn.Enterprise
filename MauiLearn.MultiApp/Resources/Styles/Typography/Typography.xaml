<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Font sizes -->
    <x:Double x:Key="TitleFontSize">22</x:Double>
    <x:Double x:Key="SubtitleFontSize">18</x:Double>
    <x:Double x:Key="BodyFontSize">16</x:Double>
    <x:Double x:Key="CaptionFontSize">13</x:Double>

    <!-- Icon sizes -->
    <x:Double x:Key="IconSize">24</x:Double>
    <x:Double x:Key="size240">28</x:Double>

    <!-- Base font style -->
    <Style x:Key="BaseFontStyle" TargetType="Label">
        <Setter Property="FontFamily"
                Value="{OnPlatform 
                            WinUI=SegoeSemibold,
                            Android=Roboto-Medium,
                            iOS=.SFUI-SemiBold,
                            MacCatalyst=.SFUI-SemiBold}" />

        <Setter Property="FontAttributes"
                Value="{OnPlatform 
                            Android=Bold,
                            Default=None}" />
    </Style>

</ResourceDictionary>