<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiLearn.MultiApp.ViewModels"
             xmlns:services="clr-namespace:MauiLearn.MultiApp.Services"
             x:Class="MauiLearn.MultiApp.Views.LoginView"
             Title="LoginView">
    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="{Binding LoginHeadline}"
           FontSize="24"
           TextColor="HotPink" />

        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="12">
            <!-- Username -->
            <Label x:Name="lblUsername" Text="Username:" VerticalOptions="Center" Grid.Row="0" Grid.Column="0"/>
            <Entry x:Name="txtUsername" Text="{Binding Username}" Placeholder="username" Grid.Row="0" Grid.Column="1"/>
            <!-- Password -->
            <Label x:Name="lblPassword" Text="Password:" Grid.Row="1" Grid.Column="0" VerticalOptions="Center" />
            <Entry x:Name="txtPassword" Text="{Binding Password}" Placeholder="password" Grid.Row="1" Grid.Column="1" IsPassword="True"/>
        </Grid>

        <Button Text="Login!" Command="{Binding SaveCommand}" />

    </VerticalStackLayout>
</ContentPage>